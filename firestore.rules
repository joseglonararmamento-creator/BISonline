rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isSignedIn() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && getUserData().role == 'student';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() > 0 
        && (data.role == 'teacher' || data.role == 'student');
    }

    function isValidLesson(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500
        && data.content is string && data.content.size() > 0
        && data.teacherId == request.auth.uid;
    }

    function isValidAssignment(data) {
      return data.title is string && data.title.size() > 0
        && data.deadline is timestamp
        && data.teacherId == request.auth.uid;
    }

    function isValidSubmission(data) {
      return data.assignmentId is string 
        && data.studentId == request.auth.uid
        && data.status == 'submitted';
    }

    function isValidComment(data) {
      return data.parentId is string && data.parentId.size() > 0
        && data.parentType is string && (data.parentType == 'post' || data.parentType == 'confession')
        && data.authorId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000;
    }

    function isValidConfession(data) {
      return data.authorId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.isAnonymous is bool;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isTeacher();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'displayName', 'photoURL', 'role', 'classNumber', 'classId', 'classIds', 
            'subjectHandled', 'yearsOfTeaching', 'gender', 'bio', 'isOnline', 'lastActive', 'updatedAt'
          ])
          || isTeacher()
        );
    }

    match /confessions/{confessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidConfession(incoming());
      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isAnonymous']))
        || (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']))
      );
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isTeacher());
    }

    match /confession_likes/{likeId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid == likeId.split('_')[1];
    }

    match /post_likes/{likeId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid == likeId.split('_')[1];
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'updatedAt']))
        || (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isTeacher());
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming());
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isTeacher());
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isValidLesson(incoming());
      allow update: if isTeacher() && existing().teacherId == request.auth.uid && isValidLesson(incoming());
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isValidAssignment(incoming());
      allow update: if isTeacher() && existing().teacherId == request.auth.uid && isValidAssignment(incoming());
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (isOwner(existing().studentId) || isTeacher());
      allow list: if isSignedIn() && (isTeacher() || (isStudent() && resource.data.studentId == request.auth.uid));
      allow create: if isStudent() && isValidSubmission(incoming());
      allow update: if isTeacher() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['grade', 'feedback', 'status']);
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isTeacher() || getUserData().get('classIds', []).hasAny([classId]) || 
          getUserData().get('classNumber', '') == classId ||
          get(/databases/$(database)/documents/classes/$(classId)).data.students.hasAny([request.auth.uid]) ||
          get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid
        );
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow delete: if isSignedIn() && (existing().senderId == request.auth.uid || isTeacher());
        allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']);
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && chatId.contains(request.auth.uid);
      allow create: if isSignedIn() && chatId.contains(request.auth.uid);
      allow update: if isSignedIn() && chatId.contains(request.auth.uid) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastRead']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && chatId.contains(request.auth.uid);
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow delete: if isSignedIn() && existing().senderId == request.auth.uid;
        allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']);
      }

      match /typing/{userId} {
        allow read: if isSignedIn() && chatId.contains(request.auth.uid);
        allow write: if isOwner(userId) && chatId.contains(request.auth.uid);
      }
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
    }

    match /quizAttempts/{attemptId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isTeacher());
      allow create: if isStudent() && incoming().studentId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isOwner(existing().senderId) || 
        isOwner(existing().receiverId) || 
        (existing().get('classId', '') == 'teachers-lounge' && isTeacher()) ||
        (existing().get('classId', null) != null && (isTeacher() || getUserData().get('classIds', []).hasAny([existing().classId]))) ||
        (existing().get('classNumber', null) != null && (isTeacher() || getUserData().get('classNumber', '') == existing().classNumber))
      );
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && (
        !incoming().keys().contains('classId') ||
        (incoming().classId == 'teachers-lounge' && isTeacher()) ||
        (incoming().get('classId', '') != 'teachers-lounge' && (isTeacher() || getUserData().get('classIds', []).hasAny([incoming().classId])))
      );
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['readBy', 'reactions'])
      );
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(resource.data.userId);
    }

    match /friends/{friendshipId} {
      allow read: if isSignedIn() && (isOwner(resource.data.user1) || isOwner(resource.data.user2));
      allow create: if isSignedIn() && incoming().user1 == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data.user1) || isOwner(resource.data.user2)) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && (isOwner(resource.data.user1) || isOwner(resource.data.user2));
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
  }
}
